{
  "name": "proxy-veil",
  "version": "1.4.4",
  "description": "MCP server for AI agents — residential proxy fetch, geo-targeting, sticky sessions, and web search. Bypass anti-bot systems invisibly. Powered by Novada.",
  "type": "module",
  "bin": {
    "proxy-veil": "build/index.js"
  },
  "files": [
    "build/**/*.js",
    "build/**/*.d.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && node --input-type=commonjs -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "dev": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "proxy",
    "residential-proxy",
    "agent-proxy",
    "ai-agents",
    "agent-to-agent",
    "web-scraping",
    "anti-bot",
    "geo-targeting",
    "novada",
    "claude",
    "cursor"
  ],
  "author": "Novada <support@novada.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "^1.7.0",
    "http-proxy-agent": "^7.0.0",
    "https-proxy-agent": "^9.0.0",
    "puppeteer-core": "^22.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  }
}
