{
  "name": "@novada/proxy-manager",
  "version": "1.0.0",
  "description": "Novada Proxy Manager - local web dashboard for managing proxy connections",
  "type": "module",
  "main": "build/server.js",
  "bin": { "novada-proxy-manager": "build/server.js" },
  "files": ["build/**/*.js", "build/**/*.d.ts", "README.md"],
  "scripts": {
    "build": "tsc && cp -r src/ui build/ui && node --input-type=commonjs -e \"require('fs').chmodSync('build/server.js', '755')\"",
    "start": "node build/server.js",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": { "@novada/proxy-core": "*" },
  "devDependencies": { "@types/node": "^20.11.24", "typescript": "^5.3.3", "vitest": "^4.1.4" },
  "engines": { "node": ">=18.0.0" },
  "license": "MIT"
}
