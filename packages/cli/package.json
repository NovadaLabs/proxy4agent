{
  "name": "@novada/proxy-cli",
  "version": "1.0.0",
  "description": "Novada Proxy CLI — residential proxy commands for terminal",
  "type": "module",
  "main": "build/cli.js",
  "bin": { "novada-proxy": "build/cli.js" },
  "files": ["build/**/*.js", "build/**/*.d.ts", "README.md"],
  "scripts": {
    "build": "tsc && node --input-type=commonjs -e \"require('fs').chmodSync('build/cli.js', '755')\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@novada/proxy-core": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  },
  "engines": { "node": ">=18.0.0" },
  "license": "MIT"
}
